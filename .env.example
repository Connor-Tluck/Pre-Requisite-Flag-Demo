# LaunchDarkly REST API access token (for the setup script)
# Create one at: https://app.launchdarkly.com/settings/authorization
LD_API_KEY=key

# LaunchDarkly project key (default: "default")
LD_PROJECT_KEY=key

# LaunchDarkly environment key (default: "production")
LD_ENVIRONMENT_KEY=key

# LaunchDarkly SDK Key (server-side, for optional server.js mode)
# Leave empty to use simulation mode (no LD account needed)
LD_SDK_KEY=key

# Port for the Express server (local dev only)
PORT=3000
